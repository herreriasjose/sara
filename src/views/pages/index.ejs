<!-- src\views\pages\index.ejs -->

<%- include('../layouts/main', { 
    title: 'SARA | Inicio',
    body: `
    <div class="hero-section text-center rounded-3 shadow-sm p-5 bg-white">
        <h1 class="display-4 fw-bold">Detección de Descompensación Emocional</h1>
        <p class="lead">Acompañamiento Bayesiano para el Cuidador</p>
        <hr class="my-4">
        
        <div class="row text-start mt-4 g-4">
            <div class="col-md-6">
                <div class="card h-100 border-primary shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-primary">Operaciones de Campo</h5>
                        <p class="card-text small text-muted">Gestión de participantes y pruebas de captura EMA.</p>
                        <div class="d-grid gap-2">
                            <a href="/register" class="btn btn-outline-primary btn-sm">Alta Cuidador (Público)</a>
                            <a href="/admin/register" class="btn btn-outline-dark btn-sm">Alta Administrativa (Investigador)</a>
                            <a href="/test-ema" class="btn btn-primary btn-sm mt-2">Simular Envío EMA (20s)</a>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0 bg-light">
                    <div class="card-body">
                        <h5 class="card-title">Estatus Técnico</h5>
                        <ul class="list-unstyled small">
                            <li><span class="badge bg-success me-2">Online</span> Node.js v24 Gateway</li>
                            <li><span class="badge bg-secondary me-2">Model</span> Caretaker (Active)</li>
                            <li><span class="badge bg-info me-2">RGPD</span> Middleware Activo</li>
                        </ul>
                        <p class="card-text text-muted small mt-3">Base de Datos: MongoDB Atlas conectada con éxito.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row text-start mt-4">
            <div class="col-12">
                <div class="card border-danger shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-danger">Gestión de Bóveda RGPD (Admin)</h5>
                        <p class="card-text small text-muted">Operaciones de auditoría y derecho al olvido.</p>
                        
                        <div class="mb-4">
                            <a href="/api/caretakers" target="_blank" class="btn btn-outline-info btn-sm">
                                📊 Recuperar y Descifrar Bóveda (JSON)
                            </a>
                        </div>

                        <hr>

                        <form id="deleteForm" onsubmit="deleteCaretaker(event)">
                            <label class="form-label small fw-bold">Anonimización Irreversible (Derecho al Olvido)</label>
                            <div class="input-group input-group-sm w-75">
                                <input type="text" id="deleteExternalId" class="form-control" placeholder="Introduce el externalId a borrar" required>
                                <button class="btn btn-danger" type="submit">Borrar Identidad</button>
                            </div>
                            <div id="deleteAlert" class="form-text mt-2"></div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 pt-4">
            <p class="text-muted small">Hacia el Doctorado 2027 | Pilotaje: Sept-Dic 2026</p>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="saraToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <strong class="me-auto">SARA:</strong> <span id="toastMessage"></span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Inyección usando interpolación de JS, no de EJS, para evitar colapsar el parser
        var serverMessage = "${message || ''}";
        
        if (serverMessage && serverMessage !== "null") {
            var toastEl = document.getElementById('saraToast');
            if (toastEl) {
                document.getElementById('toastMessage').innerText = serverMessage;
                // Inicialización segura: Bootstrap ya está cargado aquí
                var toast = new bootstrap.Toast(toastEl);
                toast.show();
                
                // Clean PRG: Limpiar la URL sin recargar para evitar re-triggers
                window.history.replaceState({}, document.title, "/");
            }
        }
    });

    // La función de borrado permanece fuera o dentro, pero se activa por evento
    async function deleteCaretaker(event) {
        event.preventDefault();
        var extId = document.getElementById('deleteExternalId').value.trim();
        var alertBox = document.getElementById('deleteAlert');
        alertBox.innerHTML = '<span class="text-muted small">Procesando...</span>';
        
        try {
            var response = await fetch('/api/caretakers/' + extId, { method: 'DELETE' });
            var data = await response.json();
            if (response.ok) {
                alertBox.innerHTML = '<span class="text-success small fw-bold">✓ ' + data.message + '</span>';
                document.getElementById('deleteExternalId').value = '';
            } else {
                alertBox.innerHTML = '<span class="text-danger small">✗ ' + (data.message || data.error) + '</span>';
            }
        } catch (error) {
            alertBox.innerHTML = '<span class="text-danger small">✗ Error de conexión.</span>';
        }
    }
    </script>
` }) %>
 