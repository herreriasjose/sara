                                <label class="form-label small fw-bold">Nombre o Alias</label>
                                <input type="text" name="alias" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Correo Electrónico o Teléfono</label>
                                <input type="text" name="contacto" class="form-control" required>
                            </div>
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary">Enviar Solicitud de Valoración</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
` }) %>
 