<!-- src\views\pages\register-researcher.ejs -->

<%- include('../layouts/main', { 
    title: 'SARA | Alta Investigador',
    body: `
<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h2 class="h4 fw-bold">Alta de Investigador</h2>
            </div>
            
            <form id="researcherForm" class="sara-form">
                <input type="hidden" id="token" value="${typeof token !== 'undefined' ? token : ''}">
                
                <div class="mb-4">
                    <h6 class="fw-bold border-bottom pb-2 text-primary">1. Identidad y Trazabilidad Ética</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="firstName" class="form-label small fw-bold">Nombre Legal</label>
                            <input type="text" id="firstName" class="form-control form-control-sm" required autocomplete="given-name">
                        </div>
                        <div class="col-md-6">
                            <label for="lastName" class="form-label small fw-bold">Apellidos</label>
                            <input type="text" id="lastName" class="form-control form-control-sm" required autocomplete="family-name">
                        </div>
                        <div class="col-12">
                            <label for="alias" class="form-label small fw-bold">Alias (Visible en WhatsApp)</label>
                            <input type="text" id="alias" class="form-control form-control-sm" placeholder="Ej. Dr. Martínez" required>
                        </div>
                    </div>
                </div>

                <div class="mb-4 p-3 bg-light rounded shadow-sm">
                    <h6 class="fw-bold border-bottom pb-2 text-primary">2. Contacto y Credenciales</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="email" class="form-label small fw-bold">Correo</label>
                            <input type="email" id="email" class="form-control form-control-sm" required autocomplete="email">
                        </div>
                        <div class="col-md-6">
                            <label for="mobile" class="form-label small fw-bold">Móvil (Alertas)</label>
                            <input type="tel" id="mobile" class="form-control form-control-sm" pattern="^\\+?[0-9\\s\\-]{9,15}$" title="Debe contener entre 9 y 15 dígitos." required autocomplete="tel">
                        </div>
                        <div class="col-md-6">
                            <label for="password" class="form-label small fw-bold">Contraseña</label>
                            <input type="password" id="password" class="form-control form-control-sm" required 
                                pattern="(?=.*\\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" 
                                title="Mínimo 8 caracteres, al menos una mayúscula, una minúscula y un número.">
                        </div>
                        <div class="col-md-6">
                            <label for="confirmPassword" class="form-label small fw-bold">Confirmar Contraseña</label>
                            <input type="password" id="confirmPassword" class="form-control form-control-sm" required>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                            <div class="alert alert-secondary py-2 px-3 mt-3 mb-0 border-0 shadow-sm rounded bg-light">
                                    <div class="d-flex align-items-center">
                                        <span class="fs-4 me-2 text-primary">🛡️</span>
                                        <p class="small text-muted mb-0" style="font-size: 0.8rem; line-height: 1.4;">
                                            <strong>Privacidad por Diseño:</strong> Los datos introducidos se almacenan segregados y utilizando cifrado avanzado (AES-256). <strong>Bajo ninguna circunstancia</strong> su información será comercializada, compartida con terceros o utilizada para fines publicitarios.
                                        </p>
                                    </div>
                                </div>
                        </div>

                <div id="statusMessage" style="display: none;" class="alert alert-info py-2 mt-3 mb-3 text-center small fw-bold"></div>

                <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100 mt-3 shadow-sm fw-bold">
                    Darse de Alta
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('researcherForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const btn = document.getElementById('submitBtn');
    const status = document.getElementById('statusMessage');
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirmPassword').value;

    if (password !== confirmPassword) {
        status.className = 'alert alert-danger py-2 mb-3 text-center small fw-bold';
        status.innerText = 'Error: Las contraseñas no coinciden.';
        status.style.display = 'block';
        return;
    }

    btn.disabled = true;
    btn.innerText = 'Cifrando e instanciando Bóveda...';
    status.style.display = 'none';

    const currentToken = document.getElementById('token').value;
    const payload = {
        firstName: document.getElementById('firstName').value,
        lastName: document.getElementById('lastName').value,
        alias: document.getElementById('alias').value,
        email: document.getElementById('email').value,
        mobile: document.getElementById('mobile').value,
        password: password
    };

    try {
        const response = await fetch('/api/researchers/register/' + currentToken, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (response.ok) {
            status.className = 'alert alert-success py-2 mb-3 text-center small fw-bold';
            status.innerText = 'Bóveda configurada correctamente. Redirigiendo...';
            status.style.display = 'block';
            setTimeout(() => window.location.href = '/admin', 2000);
        } else {
            throw new Error(data.error || 'Error de concurrencia en la instanciación.');
        }
    } catch (error) {
        status.className = 'alert alert-danger py-2 mb-3 text-center small fw-bold';
        status.innerText = error.message;
        status.style.display = 'block';
        btn.disabled = false;
        btn.innerText = 'Inicializar Bóveda Investigador';
    }
});
</script>
    ` 
}) %>