<!-- src\views\pages\ema.ejs -->

<%- include('../layouts/main', { 
    title: 'SARA | Formulario de Monitorización (EMA)', 
    body: `
    <div class="container mt-4" style="max-width: 500px;">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h4 mb-4 text-center">Formulario EMA</h2>
                
                <form id="emaForm" data-token="${locals.token}">
                    <div class="mb-4">
                        <label class="form-label fw-bold">1. ¿Cuánta energía tienes ahora?</label>
                        <div class="d-flex justify-content-between">
                            <span class="small text-muted">Baja</span>
                            <span class="small text-muted">Alta</span>
                        </div>
                        <input type="range" class="form-range custom-slider" name="energy" min="1" max="5" step="1" id="energyRange">
                        <div class="text-center fw-bold text-primary" id="energyVal">3</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">2. Nivel de agobio/tensión:</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="tension" id="t1" value="1" required>
                            <label class="btn btn-outline-success" for="t1">Calma</label>

                            <input type="radio" class="btn-check" name="tension" id="t2" value="2" checked>
                            <label class="btn btn-outline-warning" for="t2">Normal</label>

                            <input type="radio" class="btn-check" name="tension" id="t3" value="3">
                            <label class="btn btn-outline-danger" for="t3">Límite</label>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">3. ¿Tu mente está clara?</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="clarity" id="c1" value="1" required>
                            <label class="btn btn-outline-danger" for="c1">Niebla</label>

                            <input type="radio" class="btn-check" name="clarity" id="c2" value="2" checked>
                            <label class="btn btn-outline-secondary" for="c2">Difusa</label>

                            <input type="radio" class="btn-check" name="clarity" id="c3" value="3">
                            <label class="btn btn-outline-primary" for="c3">Clara</label>
                        </div>
                    </div>

                    <button type="submit" id="submitBtn" class="btn btn-primary btn-lg w-100 shadow-sm mt-3">
                        Enviar Registro
                    </button>
                    
                    <div id="statusAlert" class="mt-3 text-center small fw-bold d-none"></div>
                </form>
            </div>
        </div>
    </div>

    <style>
        .custom-slider { height: 2.5rem; }
        .btn-group .btn { padding: 1rem 0.5rem; font-weight: bold; }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const startTime = Date.now();
            const form = document.getElementById('emaForm');
            const energyRange = document.getElementById('energyRange');
            const energyVal = document.getElementById('energyVal');
            const statusAlert = document.getElementById('statusAlert');
            const submitBtn = document.getElementById('submitBtn');

            energyRange.addEventListener('input', function() {
                energyVal.innerText = this.value;
            });

            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                submitBtn.disabled = true;
                
                const payload = {
                    energy: form.energy.value,
                    tension: form.querySelector('input[name="tension"]:checked').value,
                    clarity: form.querySelector('input[name="clarity"]:checked').value,
                    responseTimeMs: Date.now() - startTime
                };

                try {
                    const response = await fetch('', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });

                    if (response.ok) {
                        form.style.display = 'none';
                        statusAlert.innerText = 'Registro procesado. Ventana cerrada.';
                        statusAlert.className = 'mt-3 text-center small fw-bold text-success';
                    } else {
                        throw new Error('Validación rechazada');
                    }
                } catch (error) {
                    submitBtn.disabled = false;
                    statusAlert.innerText = 'Enlace caducado o error de red.';
                    statusAlert.className = 'mt-3 text-center small fw-bold text-danger';
                }
            });
        });
    </script>
` }) %>