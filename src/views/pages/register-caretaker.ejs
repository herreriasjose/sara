<!-- src\views\pages\register-caretaker.ejs -->
<%- include('../layouts/main', { body: `
<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h2 class="h4 text-center mb-3">Únete a SARA</h2>
            <p class="text-muted small text-center mb-4">Configura tu perfil de acompañamiento personalizado.</p>
            
            <form action="/api/patients" method="POST">
                <div class="mb-4">
                    <h6 class="fw-bold border-bottom pb-2">Identificación</h6>
                    <div class="row g-3">
                        <div class="col-md-7">
                            <label class="form-label small">Nombre o Alias</label>
                            <input type="text" name="name" class="form-control" placeholder="Tu nombre" required>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small">Código Postal</label>
                            <input type="text" name="postalCode" class="form-control" placeholder="28001">
                        </div>
                        <div class="col-12">
                            <label class="form-label small">WhatsApp (ID de acceso)</label>
                            <input type="text" name="externalId" class="form-control" placeholder="WA-6XXXXXXXX" required>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold border-bottom pb-2">Contexto del Cuidado</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Vínculo con el familiar</label>
                            <select name="relationship" class="form-select">
                                <option value="child">Hijo/a</option>
                                <option value="spouse">Cónyuge / Pareja</option>
                                <option value="sibling">Hermano/a</option>
                                <option value="professional">Cuidador Profesional</option>
                                <option value="other">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Años cuidando</label>
                            <input type="number" name="yearsCaregiving" class="form-control" min="0">
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Discapacidad de la persona que cuidas (%)</label>
                            <input type="number" name="patientDisabilityGrade" class="form-control" placeholder="Ej: 75" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Tu grado de discapacidad, si tienes (%)</label>
                            <input type="number" name="caretakerDisabilityGrade" class="form-control" value="0">
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="fw-bold border-bottom pb-2">Contacto de Respaldo</h6>
                    <input type="email" name="email" class="form-control mb-2" placeholder="Email (opcional)">
                    <div class="card bg-light border-0 mt-3">
                        <div class="card-body py-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="consentAccepted" value="true" id="rgpd" required>
                                <label class="form-check-label small fw-bold" for="rgpd">
                                    He leído y acepto el consentimiento informado.
                                </label>
                                <div class="form-text mt-1" style="font-size: 0.75rem;">
                                    Tus datos serán tratados de forma confidencial para fines exclusivos de investigación académica y soporte emocional.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                    Comenzar Acompañamiento
                </button>
            </form>
        </div>
    </div>
</div>
` }) %>