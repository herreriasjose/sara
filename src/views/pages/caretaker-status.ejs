<% 
  // 1. Pre-procesamiento de datos (Capa de Preparación)
  // Resolvemos el conflicto de tags anidados serializando el JSON antes de la inyección en el layout.
  const chartData = JSON.stringify(locals.entries.slice(0, 20).reverse().map(e => ({
    label: e.dispatchedAt ? new Date(e.dispatchedAt).toLocaleDateString("es-ES", {day:"2-digit", month:"2-digit"}) : "—",
    energy: e.metrics?.energy || 0,
    tension: e.metrics?.tension || 0,
    clarity: e.metrics?.clarity || 0
  })));
%>

<%- include('../layouts/main', {
title: 'SARA | Estado Clínico del Cuidador',
body: `
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded border shadow-sm text-start">
        <div>
            <h4 class="mb-0 text-primary fw-bold">Estado Clínico</h4>
            <span class="badge bg-secondary mt-1">${locals.clinical.externalId || locals.clinical._id}</span>
        </div>
        <a href="/admin" class="btn btn-outline-dark btn-sm shadow-sm">← Volver al Panel</a>
    </div>

    <div class="row g-4 text-start">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body">
                    <h5 class="card-title text-primary border-bottom pb-2">Métricas Base (ERP)</h5>
                    <ul class="list-unstyled mt-3 small">
                        <li class="mb-2"><strong>Racha (Streak):</strong> ${locals.clinical.streakCount}</li>
                        <li class="mb-2"><strong>Probabilidad Burnout:</strong> ${((locals.clinical.lastBurnoutProbability || 0.5) * 100).toFixed(1)}%</li>
                        <li class="mb-2"><strong>Última Interacción:</strong> ${locals.clinical.lastInteractionAt ? new Date(locals.clinical.lastInteractionAt).toLocaleString('es-ES') : 'N/A'}</li>
                        <li class="mb-2"><strong>Ancla Matutina:</strong> <span class="badge bg-info text-dark">${locals.clinical.morningAnchor || 'No definida'}</span></li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body">
                    <h5 class="card-title text-primary border-bottom pb-2">Auditoría de Registros EMA</h5>
                    <div class="table-responsive mt-3" style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-hover align-middle small">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Recepción</th>
                                    <th>Energía</th>
                                    <th>Tensión</th>
                                    <th>Respuesta (ms)</th>
                                    <th>Trazabilidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${locals.entries && locals.entries.length > 0 ? 
                                    locals.entries.map(e => {
                                        const dateDisp = e.dispatchedAt ? new Date(e.dispatchedAt).toLocaleString('es-ES', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) : '—';
                                        const simBadge = e.isSimulated ? '<span class="badge bg-warning text-dark me-1">SIM</span>' : '';
                                        
                                        let statusBadge = '';
                                        if (e.status === 'pending') statusBadge = '<span class="badge bg-secondary">ESPERA</span>';
                                        else if (e.status === 'expired') statusBadge = '<span class="badge bg-dark">OMITIDO</span>';
                                        else statusBadge = e.isHighQuality ? '<span class="badge bg-success">VÁLIDO</span>' : '<span class="badge bg-danger">RUIDO</span>';
                                        
                                        return '<tr>' +
                                            '<td>' + dateDisp + '</td>' +
                                            '<td class="fw-bold">' + (e.metrics?.energy || '—') + '/5</td>' +
                                            '<td>' + (e.metrics?.tension || '—') + '/3</td>' +
                                            '<td>' + (e.responseTimeMs || '—') + '</td>' +
                                            '<td>' + simBadge + statusBadge + '</td>' +
                                        '</tr>';
                                    }).join('') 
                                : '<tr><td colspan="5" class="text-center text-muted py-4">Sin registros.</td></tr>'}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2 text-start">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-white">
                <div class="card-body">
                    <h5 class="card-title text-primary border-bottom pb-2">Cinética de Carga Alostática</h5>
                    <div style="height: 350px; position: relative;">
                        <canvas id="emaEvolutionChart" data-series='${chartData}'></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    (function() {
        const initChart = () => {
            const canvas = document.getElementById('emaEvolutionChart');
            if (!canvas || !canvas.dataset.series) return;

            const rawData = JSON.parse(canvas.dataset.series);
            
            new Chart(canvas, {
                type: 'line',
                data: {
                    labels: rawData.map(d => d.label),
                    datasets: [
                        {
                            label: 'Energía (Resiliencia α)',
                            data: rawData.map(d => d.energy),
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            tension: 0.4,
                            fill: true,
                            pointStyle: 'circle',
                            pointRadius: 4
                        },
                        {
                            label: 'Tensión (Desgaste β)',
                            data: rawData.map(d => d.tension),
                            borderColor: '#dc3545',
                            borderDash: [5, 5],
                            tension: 0.4,
                            pointStyle: 'rectRot',
                            pointRadius: 5
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            max: 5,
                            ticks: { stepSize: 1 },
                            title: { display: true, text: 'Magnitud Alostática', font: { size: 10 } }
                        },
                        x: { grid: { display: false } }
                    },
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 10 } },
                        tooltip: { backgroundColor: 'rgba(0,0,0,0.8)' }
                    }
                }
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initChart);
        } else {
            initChart();
        }
    })();
</script>
` }) %>