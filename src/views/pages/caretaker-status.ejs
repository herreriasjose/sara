 <!-- src\views\pages\caretaker-status.ejs -->

<%- include('../layouts/main', {
title: 'SARA | Estado Clínico del Cuidador',
body: `
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded border shadow-sm text-start">
        <div>
            <h4 class="mb-0 text-primary fw-bold">Estado Clínico</h4>
            <span class="badge bg-secondary mt-1">${locals.clinical.externalId || locals.clinical._id}</span>
        </div>
        <a href="/admin" class="btn btn-outline-dark btn-sm shadow-sm">← Volver al Panel</a>
    </div>

    <div class="row g-4 text-start">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body">
                    <h5 class="card-title text-primary border-bottom pb-2">Métricas Base (ERP)</h5>
                    <ul class="list-unstyled mt-3 small">
                        <li class="mb-2"><strong>Racha (Streak):</strong> ${locals.clinical.streakCount}</li>
                        <li class="mb-2"><strong>Probabilidad Burnout:</strong> ${((locals.clinical.lastBurnoutProbability || 0) * 100).toFixed(1)}%</li>
                        <li class="mb-2"><strong>Última Interacción:</strong> ${locals.clinical.lastInteractionAt ? new Date(locals.clinical.lastInteractionAt).toLocaleString('es-ES') : 'N/A'}</li>
                        <li class="mb-2"><strong>Ancla Matutina:</strong> <span class="badge bg-info text-dark">${locals.clinical.morningAnchor || 'No definida'}</span></li>
                        <li class="mb-2"><strong>Zona Horaria:</strong> ${locals.clinical.timezone || 'UTC'}</li>
                    </ul>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card h-100 shadow-sm border-0 bg-white">
                <div class="card-body">
                    <h5 class="card-title text-primary border-bottom pb-2">Auditoría de Registros EMA</h5>
                    <div class="table-responsive mt-3" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover align-middle small">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Recepción</th>
                                    <th>Apertura</th>
                                    <th>Completado</th>
                                    <th>Energía</th>
                                    <th>Tensión</th>
                                    <th>Claridad</th>
                                    <th>Respuesta (ms)</th>
                                    <th>Trazabilidad</th>
                                </tr>
                            </thead>
                            <tbody>
                                ${locals.entries && locals.entries.length > 0 ? 
                                    locals.entries.map(e => {
                                        const dateDisp = e.dispatchedAt ? new Date(e.dispatchedAt).toLocaleString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '—';
                                        const tOpen = e.openedAt ? new Date(e.openedAt).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '—';
                                        const tComp = e.completedAt ? new Date(e.completedAt).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '—';
                                        
                                        const simBadge = e.isSimulated ? '<span class="badge bg-warning text-dark me-1" title="Evento Simulado (Cortafuegos Activo)">SIMULADO</span>' : '';
                                        
                                        let statusBadge = '';
                                        if (e.status === 'pending') {
                                            statusBadge = '<span class="badge bg-secondary">EN ESPERA</span>';
                                        } else if (e.status === 'expired') {
                                            statusBadge = '<span class="badge bg-dark" title="Biomarcador: Omisión de respuesta">OMITIDO (ERP)</span>';
                                        } else {
                                            statusBadge = e.isHighQuality ? '<span class="badge bg-success">VÁLIDO</span>' : '<span class="badge bg-danger" title="Tiempo de respuesta fuera de umbral">DESCARTADO</span>';
                                        }
                                        
                                        return '<tr>' +
                                            '<td>' + dateDisp + '</td>' +
                                            '<td>' + tOpen + '</td>' +
                                            '<td>' + tComp + '</td>' +
                                            '<td class="fw-bold">' + (e.metrics?.energy ? e.metrics.energy + '/5' : '—') + '</td>' +
                                            '<td>' + (e.metrics?.tension ? e.metrics.tension + '/3' : '—') + '</td>' +
                                            '<td>' + (e.metrics?.clarity ? e.metrics.clarity + '/3' : '—') + '</td>' +
                                            '<td>' + (e.responseTimeMs ? e.responseTimeMs : '—') + '</td>' +
                                            '<td>' + simBadge + statusBadge + '</td>' +
                                        '</tr>';
                                    }).join('') 
                                : '<tr><td colspan="8" class="text-center text-muted py-4">No hay métricas alostáticas registradas.</td></tr>'}
                            </tbody>
                    </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
` }) %>