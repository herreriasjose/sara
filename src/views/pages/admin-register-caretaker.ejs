<%- include('../layouts/main', { body: `
<div class="container mt-4" style="max-width: 900px;">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
            <li class="breadcrumb-item active">Alta de Participante</li>
        </ol>
    </nav>

    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Registro Manual de Cuidador (Modo Investigador)</h5>
        </div>
        <div class="card-body p-4">
            <form action="/api/caretakers" method="POST">
                <input type="hidden" name="consentAccepted" value="true">

                <div class="row">
                    <div class="col-md-6 border-end">
                        <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">1. Perfil del Cuidador</h6>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nombre o Alias</label>
                            <input type="text" name="name" class="form-control form-control-sm" placeholder="Juan Pérez" maxlength="100" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Discapacidad Cuidador (%)</label>
                            <input type="number" name="caretakerDisabilityGrade" class="form-control form-control-sm" value="0" min="0" max="100">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Teléfono Móvil (WhatsApp)</label>
                            <input type="tel" name="phoneNumber" class="form-control form-control-sm" placeholder="+34 600 000 000" pattern="^\\+?[0-9\\s\\-]{9,15}$" title="Debe contener entre 9 y 15 dígitos. Puede incluir el prefijo internacional (+)." required>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">Edad</label>
                                <input type="number" name="age" class="form-control form-control-sm" min="10" max="110" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">Sexo</label>
                                <select name="gender" class="form-select form-select-sm" required>
                                    <option value="female">Mujer</option>
                                    <option value="male">Hombre</option>
                                    <option value="other">Otro</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Código Postal</label>
                            <input type="text" name="postalCode" class="form-control form-control-sm" placeholder="28001" pattern="^[0-9]{5}$" maxlength="5" title="Debe ser un código postal válido de 5 dígitos numéricos." required>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email de Respaldo</label>
                            <input type="email" name="email" class="form-control form-control-sm" placeholder="email@ejemplo.com" maxlength="150">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">2. La Díada y Carga (ERP)</h6>
                        
                            <div class="mb-3">
                            <label class="form-label small fw-bold">Vínculo</label>
                            <select name="relationship" class="form-select form-select-sm" required>
                                <option value="child">Hijo/a</option>
                                <option value="spouse">Cónyuge / Pareja</option>
                                <option value="sibling">Hermano/a</option>
                                <option value="professional">Cuidador Profesional</option>
                                <option value="other">Otro</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Discapacidad Paciente (%)</label>
                            <input type="number" name="patientDisabilityGrade" class="form-control form-control-sm" placeholder="Ej: 75" min="0" max="100" required>
                        </div>

                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Años en el rol de cuidado</label>
                            <input type="number" name="yearsCaregiving" class="form-control form-control-sm" min="0" max="100" required>
                        </div>

                        <div class="row">
                        <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">Edad Paciente</label>
                                <input type="number" name="patientAge" class="form-control form-control-sm" min="10" max="110" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">Sexo Paciente</label>
                                <select name="patientGender" class="form-select form-select-sm" required>
                                    <option value="female">Mujer</option>
                                    <option value="male">Hombre</option>
                                    <option value="other">Otro</option>
                                </select>
                            </div>
                            </div>


                        <div class="mb-3">
                            <label class="form-label small fw-bold">Tipo de Carga Principal</label>
                            <select name="burdenType" class="form-select form-select-sm" required>
                                <option value="physical">Física (Movilidad, aseo...)</option>
                                <option value="cognitive">Cognitiva (Demencia, conducta...)</option>
                                <option value="mixed">Mixta (Ambas por igual)</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">¿Dispone de apoyo externo?</label>
                            <select name="hasExternalSupport" class="form-select form-select-sm" required>
                                <option value="true">Sí (Ayuda familiar o profesional)</option>
                                <option value="false">No (Cuida solo/a)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning mt-3 border-0 py-2 small d-flex align-items-center">
                    <i class="bi bi-shield-check-fill fs-4 me-3"></i>
                    <div>
                        <strong>Confirmación del Investigador:</strong> Al finalizar el alta, declaras que el participante ha firmado el consentimiento informado pertinente para el tratamiento de datos de salud bajo el protocolo SARA.
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/" class="btn btn-outline-secondary px-4">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold">
                        Finalizar Alta de Participante
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
` }) %>