<!-- src\views\pages\admin-register-caretaker.ejs -->

<%- include('../layouts/main', { body: `
<div class="container mt-4" style="max-width: 800px;">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
            <li class="breadcrumb-item active">Alta de Participante</li>
        </ol>
    </nav>

    <div class="card border-primary shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0">Registro Manual de Cuidador (Modo Investigador)</h5>
        </div>
        <div class="card-body p-4">
            <form action="/api/patients" method="POST">
                <input type="hidden" name="consentAccepted" value="true">

                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-primary fw-bold mb-3">Identificación y Contacto</h6>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nombre Completo o Alias</label>
                            <input type="text" name="name" class="form-control" placeholder="Juan Pérez" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">WhatsApp ID (Principal)</label>
                            <input type="text" name="externalId" class="form-control" placeholder="WA-346XXXXXXXX" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Teléfono Alternativo / Fijo</label>
                            <input type="text" name="phoneAlt" class="form-control" placeholder="91XXXXXXX">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email de Respaldo</label>
                            <input type="email" name="email" class="form-control" placeholder="email@ejemplo.com">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h6 class="text-primary fw-bold mb-3">Contexto de la Investigación</h6>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Relación con el dependiente</label>
                            <select name="relationship" class="form-select">
                                <option value="child">Hijo/a</option>
                                <option value="spouse">Cónyuge / Pareja</option>
                                <option value="sibling">Hermano/a</option>
                                <option value="professional">Cuid. Profesional</option>
                                <option value="other">Otro</option>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">Edad</label>
                                <input type="number" name="age" class="form-control" min="18" max="120">
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label small fw-bold">CP</label>
                                <input type="text" name="postalCode" class="form-control" placeholder="28001">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Años en el rol de cuidador</label>
                            <input type="number" name="yearsCaregiving" class="form-control" min="0" value="0">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Grado Discapacidad del PACIENTE (%)</label>
                            <input type="number" name="patientDisabilityGrade" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Grado Discapacidad del CUIDADOR (%)</label>
                            <input type="number" name="caretakerDisabilityGrade" class="form-control" value="0">
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning mt-3 border-0 py-2 small">
                    <i class="bi bi-shield-lock-fill me-2"></i>
                    Al pulsar registrar, confirmas que el participante ha firmado el consentimiento informado físico o digital.
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary px-5">
                        Finalizar Alta de Participante
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
` }) %>