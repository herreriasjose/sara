<!-- src\views\layouts\main.ejs -->

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; color: #212529; }
        .hero-section { padding: 60px 0; background: #fff; border-bottom: 1px solid #dee2e6; }
        .main-link { text-decoration: none; color: #fff; }
        .admin-login-link { font-size: 0.8rem; text-decoration: none; color: #adb5bd; }
        .admin-login-link:hover { color: #fff; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container d-flex justify-content-between">
            <span class="navbar-brand mb-0 h1"><a href="/" class="main-link">SARA</a> | Sistema de Acompañamiento y Resiliencia Alostática</span>
            <div style="width: 100px;"></div>
            <div>
                <% if (locals.isAuthenticated) { %>
                    <% if (locals.currentPath && !locals.currentPath.startsWith('/admin')) { %>
                        <a href="/admin" class="admin-login-link me-3">Panel Investigadores</a>
                    <% } %>
                    <form action="/api/logout" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-link admin-login-link p-0 text-decoration-none shadow-none">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="admin-login-link">Acceso Investigador</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container mt-5">
        <%- body %>
    </main>

    <footer class="container text-center mt-5 py-4 text-muted border-top">
        <small></small>
    </footer>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>