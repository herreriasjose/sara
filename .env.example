# =================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =================================================================
PORT=3000
NODE_ENV=development
# URL base para la generación de enlaces en los mensajes de WhatsApp
BASE_URL=https://tudominio.es 

# =================================================================
# BASE DE DATOS (MongoDB Atlas - Tier M0)
# =================================================================
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/tfm_database 
# Plazo para borrar los registros caducados (86400 = 1 día)
INVITATION_TTL=86400

# =================================================================
# SEGURIDAD Y SESIONES (GDPR Compliant)
# =================================================================
# Genera strings largos y aleatorios para proteger la sesión del usuario
SESSION_SECRET=cambiame_por_un_secreto_muy_largo
JWT_SECRET=otro_secreto_para_tokens_de_acceso

# =================================================================
# TWILIO API (Automatización EMA vía WhatsApp)
# =================================================================
# Credenciales de tu consola de Twilio
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=tu_token_de_auth
# Número de Sandbox o número adquirido para WhatsApp
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =================================================================
# PARÁMETROS DEL ESTUDIO (Configuración Metodológica)
# =================================================================
# Duración del estudio en días (Hito de recogida EMA)
STUDY_DURATION_DAYS=14
# Objetivo de muestra para asegurar robustez estadística
TARGET_N=100
