{
  "name": "sara",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node --env-file=.env src/server.js",
    "dev": "cross-env NODE_ENV=development node --env-file=.env.dev --watch src/server.js",
    "test": "cross-env NODE_ENV=test node --env-file=.env.test --test --test-concurrency=1 tests/**/*.test.js",
    "test:watch": "cross-env NODE_ENV=test node --env-file=.env.test --test-concurrency=1 --test --watch tests/**/*.test.js"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
